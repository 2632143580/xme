# ── LLM 供应商（三选一，填对应块即可）────────────────────
# 切换方式：改 LLM_PROVIDER 一行，无需动代码

LLM_PROVIDER=volcengine
# 可选值：volcengine / deepseek / openai

# ── 火山引擎 Doubao ───────────────────────────────────────────
VOLCENGINE_API_KEY=your_volcengine_api_key_here
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_MODEL=dp

# ── DeepSeek ───────────────────────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── OpenAI 兼容接口 ──────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ── 向后兼容（旧格式，LLM_PROVIDER 未设置时使用）──────────
# OPENAI_API_KEY=your_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# MODEL_NAME=gpt-4o

# ── 记忆存储 ──────────────────────────────────────────────────
SQLITE_PATH=data/sqlite/memory.db

# ── Qdrant（可选，不启动则降级为关键词搜索）───────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── Neo4j（可选，不启动则降级为无图谱）────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ── 主动调度（持久态升级，全部 .env 暴露方便对接 API/前端）────
ENABLE_SCHEDULER=false
IDLE_THRESHOLD_MINUTES=30
#  调度器核心参数
SCHEDULER_TIMEZONE=Asia/Shanghai
SCHEDULER_MAX_WORKERS=30
SCHEDULER_COALESCE=true
SCHEDULER_MAX_INSTANCES=1
SCHEDULER_JOBS_DB=data/sqlite/jobs.sqlite
SCHEDULER_MONITORING=true
#  早安问候时间（可自定义时/分）
MORNING_GREETING_HOUR=9
MORNING_GREETING_MINUTE=0
MORNING_GREETING_MISFIRE_GRACE=86400
#  提醒宽限期（秒），0 = 不错过补执行
REMINDER_MISFIRE_GRACE=3600

# ── API 服务 ─────────────────────────────────────────────────
API_PORT=8000

# ── 微信 Bot 接入（iLink 协议）────────────────────────────
# 配置说明见 config.py get_settings() -> wx_* 系列变量
WX_BASE_URL=https://ilinkai.weixin.qq.com
WX_BOT_TYPE=3
WX_POLL_TIMEOUT=35
WX_MAX_CONCURRENT=10
WX_CHANNEL_VERSION=1.0.3
